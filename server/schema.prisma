// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  username         String   @unique
  email            String   @unique
  password         String
  role             String   @default("USER") // GUEST, USER, AGENT, ADMIN
  balance          Float    @default(0)
  avatarUrl        String   @default("https://picsum.photos/seed/avatar/200/200")
  subscriptionTier String   @default("Free") // Free, Pro, Elite
  emailVerified    Boolean  @default(false)
  emailVerificationCode      String?
  emailVerificationExpiresAt DateTime?
  fullName         String?
  address          String?
  phone            String?
  paymentMethod    String?
  whatsappNumber   String?
  whatsappBotId    String?
  whatsappOptIn    Boolean  @default(false)
  whatsappWelcomeStatus String @default("NOT_REQUESTED")
  whatsappWelcomeSentAt DateTime?
  whatsappWelcomeError String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
  payments         Payment[]
  reviewedPayments Payment[] @relation("PaymentReviewer")
  sentDeliveries   Delivery[] @relation("DeliverySender")
  loyaltyPoints    LoyaltyPoint[]
  cart             Cart?
  clientNotifications ClientNotification[]
}

model Sequence {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  key       String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteVisit {
  id         String   @id @default(uuid())
  path       String
  pageType   String
  listingId  String?
  categoryId String?
  userId     String?
  visitorId  String?
  referrer   String?
  userAgent  String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([pageType])
  @@index([listingId])
  @@index([categoryId])
  @@index([visitorId])
}

model Category {
  id            String        @id @default(uuid())
  name          String
  slug          String        @unique
  icon          String
  imageUrl      String?
  gradient      String?
  description   String?
  order         Int           @default(0)
  subCategories SubCategory[]
  listings      Listing[]
}

model SubCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  icon        String?
  description String?
  order       Int       @default(0)
  listings    Listing[]
}

model Listing {
  id                String       @id @default(uuid())
  title             String
  description       String
  price             Float
  isArchived        Boolean      @default(false)
  isPackage         Boolean      @default(false)
  variantLabel      String?
  discountPercent   Int          @default(0)
  discountType      String       @default("NONE")
  discountValue     Float        @default(0)
  categoryId        String
  category          Category     @relation(fields: [categoryId], references: [id])
  subCategoryId     String?
  subCategory       SubCategory? @relation(fields: [subCategoryId], references: [id])
  logoUrl           String?
  imageUrl          String
  cardTemplate      String       @default("default")
  gallery           String       @default("[]") // JSON string array
  game              String?
  platform          String?
  region            String?
  source            String?
  activationCountry String?
  activationGuideTitle String?
  activationGuideContent String?
  restrictionsTitle String?
  restrictionsContent String?
  regionTitle       String?
  regionContent     String?
  systemRequirementsEnabled Boolean @default(false)
  systemRequirementsPlatform String?
  minimumOs         String?
  minimumMemory     String?
  minimumStorage    String?
  minimumProcessor  String?
  minimumGraphics   String?
  recommendedOs     String?
  recommendedMemory String?
  recommendedStorage String?
  recommendedProcessor String?
  recommendedGraphics String?
  stock             Int          @default(1)
  deliveryTimeHours Int          @default(24)
  isInstant         Boolean      @default(true)
  preparationTime   String?      // e.g., "2-3 jours", "Immédiat"
  salesCount        Int          @default(0)
  metaTitle         String?
  metaDesc          String?
  keywords          String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  cartItems         CartItem[]
  orderItems        OrderItem[]
  packageItems      PackageItem[] @relation("PackageComposition")
  includedInPackages PackageItem[] @relation("PackageComponent")
  variants          ProductVariant[]
}

model ProductVariant {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name      String
  price     Float
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cartItems CartItem[]
}

model PackageItem {
  id                String   @id @default(uuid())
  packageListingId  String
  includedListingId String
  quantity          Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  packageListing    Listing  @relation("PackageComposition", fields: [packageListingId], references: [id], onDelete: Cascade)
  includedListing   Listing  @relation("PackageComponent", fields: [includedListingId], references: [id], onDelete: Restrict)

  @@unique([packageListingId, includedListingId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique
  idempotencyKey      String?     @unique
  userId              String?
  user                User?       @relation(fields: [userId], references: [id])
  status              String      @default("PAYMENT_UNDER_REVIEW")
  amount              Float
  subtotal            Float       @default(0)
  discount            Float       @default(0)
  total               Float       @default(0)
  currency            String      @default("TND")
  source              String      @default("GUEST")
  customerType        String      @default("GUEST")
  guestEmail          String?
  guestPhone          String?
  cartFingerprint     String?
  trackingTokenHash   String?
  customerFirstName   String
  customerLastName    String
  customerEmail       String
  customerPhone       String
  paymentMethod       String?
  paymentConfirmedAt  DateTime?
  expiresAt           DateTime?
  emailStatus         String      @default("PENDING")
  emailSentAt         DateTime?
  emailError          String?
  items               OrderItem[]
  invoice             Invoice?
  payments            Payment[]
  deliveries          Delivery[]
  actionLogs          OrderActionLog[]
  clientNotifications ClientNotification[]
  loyaltyPoints       LoyaltyPoint[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([cartFingerprint])
  @@index([guestEmail, guestPhone, createdAt])
}

model OrderItem {
  id            String        @id @default(uuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId     String
  listing       Listing       @relation(fields: [listingId], references: [id])
  variantId     String?
  quantity      Int
  priceSnapshot Float
  titleSnapshot String
  productSnapshotImage String?
  variantSnapshot String?
  deliveryType  String        @default("MIXED")
  status        String        @default("LOCKED")
  invoiceItems  InvoiceItem[]
  deliveries    Delivery[]
}

model Invoice {
  id                String        @id @default(uuid())
  invoiceNumber     String        @unique
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type              String        @default("PROFORMA")
  status            String        @default("PENDING_PAYMENT")
  currency          String        @default("TND")
  orderNumber       String
  customerFirstName String
  customerLastName  String
  customerEmail     String
  customerPhone     String
  totalAmount       Float
  issueDate         DateTime      @default(now())
  emailSentAt       DateTime?
  emailError        String?
  items             InvoiceItem[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model InvoiceItem {
  id            String    @id @default(uuid())
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderItemId   String?
  orderItem     OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  listingId     String?
  variantSnapshot String?
  quantity      Int
  unitPrice     Float
  lineTotal     Float
  titleSnapshot String
}

model DailyStat {
  id        String   @id @default(uuid())
  date      DateTime @unique
  sales     Float    @default(0)
  orders    Int      @default(0)
  newUsers  Int      @default(0)
  createdAt DateTime @default(now())
}

model Payment {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  method          String
  status          String   @default("SUBMITTED")
  amount          Float
  currency        String   @default("TND")
  transactionRef  String?  @unique
  customerReference String?
  proofFileUrl    String?
  submittedAt     DateTime @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  reviewedBy      String?
  reviewer        User?    @relation("PaymentReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  rejectionReason String?
  recordedBy      String?
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Delivery {
  id                       String     @id @default(uuid())
  orderId                  String
  order                    Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId              String?
  orderItem                OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  status                   String     @default("LOCKED")
  deliveryContentEncrypted String
  deliveryType             String     @default("MIXED")
  activationGuide          String?
  restrictions             String?
  region                   String?
  sentAt                   DateTime?
  sentBy                   String?
  sender                   User?      @relation("DeliverySender", fields: [sentBy], references: [id], onDelete: SetNull)
  viewedAt                 DateTime?
  resendCount              Int        @default(0)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([orderId])
  @@index([orderItemId])
}

model OrderActionLog {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorType String
  actorId   String?
  action    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model ClientNotification {
  id        String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type       String   @default("SYSTEM")
  title      String
  message    String
  metadata   Json?
  readAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([orderId])
}

model LoyaltyPoint {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  points      Int
  type        String   @default("EARNED")
  description String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
